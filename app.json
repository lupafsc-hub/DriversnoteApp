{
  "expo": {
    "name": "DriversNote Pro+",
    "slug": "driversnote-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "android": {
      "package": "com.yourname.driversnote",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
